---
import type { WritingEntry } from '../data/writing';

interface Props {
  posts: WritingEntry[];
  dateFormat?: 'short' | 'long';
}

const { posts, dateFormat = 'short' } = Astro.props;

function fmt(d: Date) {
  const opts: Intl.DateTimeFormatOptions =
    dateFormat === 'long'
      ? { year: 'numeric', month: 'short', day: 'numeric' }
      : { year: 'numeric', month: 'short' };
  return d.toLocaleDateString('en-US', opts);
}
---
<ul class="post-list">
  {posts.map((p) => (
    <li>
      <a href={p.url} class="row" target="_blank" rel="noopener">
        <span>
          {p.title}
          {p.venue && <span class="venue">{p.venue}</span>}
        </span>
        <span class="date">{fmt(p.date)}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .post-list { margin: 0; }
  .post-list .row { border-bottom: 1px solid var(--line); }
  .post-list a { border-bottom: 0; }
  .post-list a:hover span:first-child { border-bottom: 1px solid var(--fg); }
  .venue {
    font-size: 12px;
    color: var(--muted);
    margin-left: 10px;
    border-bottom: 0 !important;
  }
</style>
