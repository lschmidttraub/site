---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="site-header container">
  <a href="/" class="wordmark">leo schmidt-traub</a>
  <ThemeToggle />
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    padding-bottom: 20px;
  }
  .wordmark {
    font-size: 13px;
    color: var(--muted);
    border-bottom: 0;
    transition: color .15s;
  }
  .wordmark:hover { color: var(--fg); }
</style>
