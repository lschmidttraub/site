---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Constellation from '../../components/Constellation.astro';
import { writing } from '../../data/writing';

const posts = [...writing].sort((a, b) => b.date.getTime() - a.date.getTime());

const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);

function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---
<BaseLayout title="Writing — Leo Schmidt-Traub">
  <Constellation />
  <SiteHeader />

  <main class="container fade-in">
    <p style="margin: 8px 0 32px;"><a href="/">← Home</a></p>
    <h1 style="margin-bottom: 24px;">Writing</h1>

    {years.map((year) => (
      <section class="section">
        <div class="section-label">{year}</div>
        <ul>
          {byYear.get(year)!.map((p) => (
            <li class="row">
              <a href={p.url} target="_blank" rel="noopener" style="border-bottom:0;">
                {p.title}
                {p.venue && <span class="venue">{p.venue}</span>}
              </a>
              <span class="date">{fmt(p.date)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}

    {posts.length === 0 && <p style="color: var(--muted);">Nothing yet.</p>}
  </main>
</BaseLayout>

<style>
  .venue {
    font-size: 12px;
    color: var(--muted);
    margin-left: 10px;
  }
</style>
