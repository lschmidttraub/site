---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Constellation from '../components/Constellation.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = posts.slice(0, 5);

const links = [
  { label: 'Email', href: 'mailto:leo.schmidttraub@gmail.com' },
  { label: 'GitHub', href: 'https://github.com/lschmidttraub' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/leo-schmidt-traub-155158233/' },
];
---
<BaseLayout title="Leo Schmidt-Traub">
  <Constellation />
  <SiteHeader />

  <main class="container fade-in">
    <section class="section">
      <h1>Hi, I'm Leo 👋</h1>
      <p>
        I'm a machine learning researcher. I care about. I sometimes write about
        what I'm learning.
      </p>
      <p>
        Currently: based in Zürich, reading <i>Infinite Jest</i>, building [project].
      </p>
    </section>

    <section class="section">
      <div class="section-label">About</div>
      <p>
        I grew up in [place] and studied [subject] at [university]. Before
        turning to research full-time, I worked on [previous role / project].
      </p>
      <p>
        My work sits at the intersection of [area A] and [area B]. I'm most
        interested in [specific question], and I enjoy collaborating on problems
        that span empirical and theoretical angles.
      </p>
      <p>
        Outside of work: [hobby], [hobby], and long walks with a notebook.
      </p>
    </section>

    <section class="section">
      <div class="section-label">Writing</div>
      <PostList posts={recent} />
      {posts.length > recent.length && (
        <p style="margin-top:10px;"><a href="/writing">See all →</a></p>
      )}
    </section>

    <section class="section">
      <div class="section-label">Elsewhere</div>
      <div class="links-row">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </section>

    <footer class="section" style="color: var(--muted); font-size: 12px;">
      © {new Date().getFullYear()} Leo Schmidt-Traub
    </footer>
  </main>
</BaseLayout>

<style>
  h1 { margin-bottom: 12px; }
  p { margin-bottom: 14px; }
  .links-row { display: flex; gap: 18px; flex-wrap: wrap; }
</style>
